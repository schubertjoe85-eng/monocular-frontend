{
  "expo": {
    "name": "Monocular",
    "slug": "monocular",
    "version": "1.0.0",

    "assetBundlePatterns": [
      "**/*"
    ],

    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Monocular needs access to your photos so you can upload drawings and images for rendering."
        }
      ]
    ],

    "ios": {
      "supportsTablet": true
    }
  }
}