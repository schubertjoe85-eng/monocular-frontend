{
  "expo": {
    "name": "Monocular",
    "slug": "monocular",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "monocular",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Monocular needs access to your photos so you can upload drawings and images for rendering."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.schubertjoe.monocular"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#556B2F"
      }
    },
    "web": {
      "bundler": "metro"
    }
  }
}